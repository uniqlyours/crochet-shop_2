# Copy this file to ".env" and fill in your own values.
# (On Railway you set these same keys under the service's "Variables" tab instead.)

# --- Admin login -------------------------------------------------------------
# Password for the shop admin login. CHANGE THIS before going live.
ADMIN_PASSWORD=crochet-admin
# A long random string used to sign the admin login cookie. CHANGE THIS too.
SESSION_SECRET=replace-with-a-long-random-string

# --- Site --------------------------------------------------------------------
# Port the server runs on (Railway sets this automatically; defaults to 3000 locally)
PORT=3000
# Your public website address once hosted (used for SEO sitemap & social previews)
SITE_URL=https://uniqlyours.com

# --- Persistent storage (Railway) -------------------------------------------
# Point these at a mounted Railway volume so products, orders and photos survive
# restarts/redeploys. Leave them unset locally to use the ./data and ./public/uploads
# folders. If your volume is mounted at /data, use:
# DATA_DIR=/data
# UPLOADS_DIR=/data/uploads

# --- Order email notifications (optional) -----------------------------------
# Email is OFF until SMTP_HOST + SMTP_USER + SMTP_PASS are all set.
# Use the SMTP details from wherever order@uniqlyours.com is hosted.
#   Namecheap Private Email: host mail.privateemail.com, port 465
#   Zoho Mail:               host smtp.zoho.com,         port 465
#   Google Workspace:        host smtp.gmail.com,        port 465 (use an App Password)
# SMTP_HOST=mail.privateemail.com
# SMTP_PORT=465
# SMTP_USER=order@uniqlyours.com
# SMTP_PASS=your-mailbox-password-or-app-password
# SMTP_FROM=Uniqly Yours <order@uniqlyours.com>
# ADMIN_EMAIL=order@uniqlyours.com   # where new-order alerts are sent

# --- Optional: Stripe (only needed when you want to take real card payments) ---
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PUBLISHABLE_KEY=pk_live_...

# --- Optional: Google Analytics 4 ---
# Create a GA4 property at analytics.google.com, add a Web data stream for your
# site, and paste its Measurement ID here to enable visitor tracking.
# GA_MEASUREMENT_ID=G-XXXXXXXXXX
